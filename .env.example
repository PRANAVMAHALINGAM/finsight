# ── LangSmith (get these at smith.langchain.com) ──────────────────────────────
LANGCHAIN_TRACING_V2=true         # enables tracing — just needs to be "true"
LANGCHAIN_API_KEY=your_key_here   # from smith.langchain.com → settings → API keys
LANGCHAIN_PROJECT=finsight       # the project name that shows up in LangSmith UI

# ── LLM provider ──────────────────────────────────────────────────────────────
# For local dev, use Groq (free at console.groq.com)
GROQ_API_KEY=your_key_here

# For production (optional, can stick with Groq throughout)
# OPENAI_API_KEY=your_key_here

# ── Data sources ──────────────────────────────────────────────────────────────
NEWS_API_KEY=your_key_here        # free at newsapi.org

# ── Vector DB ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_key_here    # free at pinecone.io
PINECONE_INDEX_NAME=finsight

# ── App config ────────────────────────────────────────────────────────────────
ENV=development                   # switch to "production" when deploying
